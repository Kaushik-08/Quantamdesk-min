# ─── Database ───────────────────────────────────────────────────────────────
# Copy this file to `.env` — NEVER commit `.env` to git.
DATABASE_URL="postgresql://quantumdesk:quantumdesk@localhost:5433/quantumdesk?schema=public"

# ─── App ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Demo login password — set locally after copying to .env (never commit real values)
DEMO_PASSWORD=

# ─── Optional: AI assist (Summarize / Suggest reply) ────────────────────────
# Keys stay server-side only — never use NEXT_PUBLIC_ prefix for secrets.
#
# AI_MODE=auto          # default: try OpenAI, fall back to demo on quota errors
# AI_MODE=demo          # local demo AI — no API key needed (good for submission video)
# AI_MODE=openai        # require OpenAI; fail if unavailable
#
# OPENAI_API_KEY=""     # set locally in .env only — never commit
# OPENAI_MODEL="gpt-4o-mini"
